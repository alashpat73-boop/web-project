# ============================================================
# Base Image
# ============================================================
# استخدام صورة PHP الرسمية مع Apache
# الإصدار: PHP 8.2 + Apache
# ============================================================

FROM php:8.2-apache


# ============================================================
# System Packages
# ============================================================
# تثبيت الأدوات الأساسية المستخدمة أثناء التطوير أو
# في بعض السكربتات داخل المشروع.
#
# git      : لاستنساخ المستودعات (اختياري)
# unzip    : لفك الملفات المضغوطة
# zip      : لإنشاء الملفات المضغوطة
# curl     : لاختبارات HTTP والـ Healthcheck
#
# بعد التثبيت يتم حذف ملفات apt المؤقتة لتقليل حجم الصورة.
# ============================================================

RUN apt-get update && apt-get install -y \
    git \
    unzip \
    zip \
    curl \
    && rm -rf /var/lib/apt/lists/*


# ============================================================
# PHP Extensions
# ============================================================
# تثبيت الإضافات المطلوبة للمشروع.
#
# mysqli
#     لاستخدام واجهة MySQLi.
#
# pdo
#     طبقة الاتصال الموحدة بقواعد البيانات.
#
# pdo_mysql
#     تعريف PDO الخاص بـ MySQL.
# ============================================================

RUN docker-php-ext-install \
    mysqli \
    pdo \
    pdo_mysql


# ============================================================
# Apache Modules
# ============================================================
#
# rewrite
#     لدعم روابط .htaccess و URL Rewrite.
#
# headers
#     لإضافة Security Headers مثل CSP و X-Frame-Options.
#
# expires
#     للتحكم في Cache-Control و Expires.
# ============================================================

RUN a2enmod \
    rewrite \
    headers \
    expires


# ============================================================
# Apache Security Configuration
# ============================================================
# إخفاء إصدار Apache ونظام التشغيل.
#
# قبل:
#   Apache/2.4.xx (Debian)
#
# بعد:
#   Apache
#
# هذا يقلل من المعلومات التي يحصل عليها المهاجم.
# ============================================================

RUN echo "ServerTokens Prod" > /etc/apache2/conf-available/security-custom.conf && \
    echo "ServerSignature Off" >> /etc/apache2/conf-available/security-custom.conf && \
    a2enconf security-custom


# ============================================================
# Virtual Host Configuration
# ============================================================
# نسخ إعدادات Apache الخاصة بالمشروع.
#
# يحتوي هذا الملف على:
#   • DocumentRoot
#   • Security Headers
#   • Directory Configuration
#   • Logging
# ============================================================

COPY docker/apache/vhost.conf \
     /etc/apache2/sites-available/000-default.conf


# ============================================================
# Working Directory
# ============================================================
# جميع أوامر Docker اللاحقة ستنفذ داخل هذا المجلد.
# وهو أيضاً المجلد الذي يتم ربط ملفات المشروع به.
# ============================================================

WORKDIR /var/www/html